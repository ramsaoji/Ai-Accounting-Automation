# Service Configuration
NODE_ENV=development
PORT=8080
# Connection URL for Neon DB/PostgreSQL (Optional: falls back to local files if empty)
DATABASE_URL=postgresql://neondb_owner:password@ep-host.region.pooler.neon.tech/neondb?sslmode=require

# AI Configuration (Fallback seeds used on first-time DB initialization)
# Supported providers: openai | gemini | claude | openrouter | deepseek | groq | none
DEFAULT_AI_PROVIDER=gemini
DEFAULT_AI_MODEL=gemini-1.5-flash

# Default AI toggle states for first-time database initialization (defaults to true)
# Once initialized in the database, subsequent changes should be made in the Web UI.
DEFAULT_WEB_CHAT_ENABLED=true
DEFAULT_TELEGRAM_CHAT_ENABLED=true

# AI Provider API Keys
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Google Drive API Service Account Credentials
GOOGLE_CLIENT_EMAIL=accounting-worker@your-project-id.iam.gserviceaccount.com
# Use standard PEM format (with \n escaped or as multi-line)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Telegram Bot API
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ
# Comma-separated list of authorized chat IDs (add multiple to allow multiple users)
# e.g. TELEGRAM_CHAT_ID=987654321,112233445
TELEGRAM_CHAT_ID=-1001234567890
# Comma-separated list of standard IANA timezones to format dates in Telegram messages
TELEGRAM_TIMEZONES=Asia/Kolkata,Asia/Hong_Kong,Europe/London

# Scheduler Configuration (Cron format - Runs daily at 9:00 AM IST / 3:30 AM UTC)
CRON_SCHEDULE=30 3 * * *

# Security Passcode Layer (Fallback seeds used on first-time DB initialization)
DEFAULT_UPLOAD_PASSWORD=your_secure_upload_passcode_here
DEFAULT_APP_PASSWORD=your_secure_app_lock_passcode_here
# Secret key used for signing session JWT tokens. Must be changed in production.
JWT_SECRET=your_jwt_signing_secret_key_here

# System Logging Configuration
# Enable/disable appending structured logs to logs/system.log (defaults to false)
ENABLE_FILE_LOGGING=false

# CORS & Network Origins
# Comma-separated list of allowed CORS origins for production (e.g. "https://yourdomain.com")
ALLOWED_ORIGINS=http://localhost:5173

# Business Branding
# Business display name used in AI prompts, Telegram messages, and reports
BUSINESS_NAME=Hotel Gaurav